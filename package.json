{
  "type": "module",
  "name": "maptoolkit-js",
  "version": "11.1.0-alpha.2",
  "description": "Maptoolkit Javascript Library",
  "scripts": {
    "build": "npm run build-js && npm run build-css",
    "build-js": "rollup -c --environment BUILD:production",
    "watch-js": "rollup -c -w && postcss --use postcss-import -o dist/maptoolkit.css src/index.css -w",
    "build-css": "postcss --use postcss-import -o dist/maptoolkit.css src/index.css",
    "watch-css": "postcss -w --use postcss-import -o dist/maptoolkit.css src/index.css",
    "generate-docs": "typedoc"
  },
  "author": "Daniel Böck",
  "license": "ISC",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^26.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-replace": "^5.0.5",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "postcss": "^8.4.33",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.0.0",
    "rollup": "^4.9.6",
    "rollup-plugin-dts": "^6.1.1",
    "rollup-plugin-esbuild": "^6.1.1",
    "tslib": "^2.6.2",
    "typedoc": "^0.26.5",
    "typedoc-plugin-markdown": "^4.2.2",
    "typedoc-plugin-missing-exports": "^3.0.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@mapbox/mapbox-gl-draw": "^1.4.3",
    "@mapbox/togeojson": "^0.16.2",
    "@maplibre/maplibre-gl-style-spec": "^20.1.1",
    "@turf/difference": "^7.0.0",
    "@turf/distance": "^7.0.0",
    "@turf/length": "^7.0.0",
    "@turf/union": "^7.0.0",
    "maplibre-gl": "^4.1.2"
  },
  "files": [
    "dist/*"
  ],
  "main": "dist/maptoolkit.mjs",
  "types": "dist/maptoolkit.d.ts",
  "style": "dist/maptoolkit.css",
  "exports": {
    ".": {
      "import": "./dist/maptoolkit.mjs",
      "types": "./dist/maptoolkit.d.ts"
    },
    "./style": {
      "import": "./dist/maptoolkit.css"
    }
  }
}
