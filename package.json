{
  "type": "module",
  "name": "@maptoolkit/maps-sdk",
  "version": "11.0.0-alpha.beta",
  "description": "Maps SDK by Maptoolkit powered by MapLibre GL JS",
  "scripts": {
    "build": "npm run build-js && npm run build-css",
    "build-js": "rollup -c --environment BUILD:production",
    "watch-js": "rollup -c -w --environment BUILD:development",
    "build-css": "postcss --use postcss-import -o dist/maptoolkit.css src/index.css",
    "watch-css": "postcss -w --use postcss-import -o dist/maptoolkit.css src/index.css",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "eslint ./src/",
    "pretty": "prettier ./src/**/*.{ts,js,json,css} ./test/**/*.html --write",
    "check": "npm run test && npm run lint",
    "generate-docs": "typedoc"
  },
  "author": "Daniel Böck",
  "license": "ISC",
  "files": [
    "dist/*"
  ],
  "main": "dist/maptoolkit.mjs",
  "types": "dist/maptoolkit.d.ts",
  "style": "dist/maptoolkit.css",
  "exports": {
    ".": {
      "import": "./dist/maptoolkit.mjs",
      "types": "./dist/maptoolkit.d.ts"
    },
    "./css": {
      "import": "./dist/maptoolkit.css"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/maptoolkit/maptoolkit-js.git"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-replace": "^6.0.2",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.31.0",
    "jest": "^29.7.0",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.0",
    "prettier": "^3.5.3",
    "rollup": "^4.40.0",
    "rollup-plugin-dts": "^6.2.1",
    "rollup-plugin-esbuild": "^6.2.1",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.3",
    "typedoc-plugin-markdown": "^4.6.3",
    "typedoc-plugin-missing-exports": "^4.0.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@mapbox/mapbox-gl-draw": "^1.5.0",
    "@mapbox/togeojson": "^0.16.2",
    "@maplibre/maplibre-gl-style-spec": "^23.2.1",
    "@turf/difference": "^7.2.0",
    "@turf/distance": "^7.2.0",
    "@turf/length": "^7.2.0",
    "@turf/union": "^7.2.0",
    "maplibre-gl": "^5.6.1",
    "pbf": "^4.0.1"
  }
}
